# Copy this file to .env and edit. `docker compose` reads .env automatically.
# .env is gitignored at the repo root; don't commit credentials.

# --- Image source ------------------------------------------------------------

# By default the compose pulls the published multi-arch images from Docker
# Hub (ikaronclaude/fiesta-*:latest) -- they contain both linux and windows
# variants under one tag, so on a Windows engine you get the windows build
# with no local build needed. To use your own locally-built images, point
# these at the local tags (see ../README.md "Building your own base images"):
#RUNTIME_IMAGE=fiesta-server-runtime:latest
#SQL_IMAGE=fiesta-sql-runtime:latest
#PROXY_IMAGE=fiesta-proxy:latest

# --- Required -----------------------------------------------------------------

# Absolute path on the host to your server files (the standard 9Data/ + per-process exe tree). Must contain
# 9Data/, Login/, WorldManager/, Zone00/..Zone04/, Account/,
# AccountLog/, Character/, GameLog/, Databases/ (with your .bak files).
# Use forward slashes; Docker Desktop accepts them.
FIESTA_SERVER=C:/path/to/your/server-files

# SA password for the bundled SQL Server. Used for the .bak restore on first
# boot and for every ODBC connection inside the stack. Must satisfy SQL Server's
# default complexity policy (8+ chars, mixed classes).
SA_PASSWORD=Fiesta!Strong1

# The IP your *external* players reach the host on. Goes into the
# WORLDSELECT_ACK / CHAR_LOGIN_ACK rewrites the proxy does.
#   * Local-only test:                  127.0.0.1
#   * LAN-only test:                    your machine's LAN IP (ipconfig)
#   * Internet-facing (port-forwarded): your WAN IP
PUBLIC_IP=127.0.0.1

# --- SQL Server selection ----------------------------------------------------

# By default the stack runs a bundled SQL Server (Express) container alongside
# the game services. Three escape hatches, in priority order:
#
#   Tier 1 -- full ODBC connection string (wins over everything else).
#     Use this when you need driver flags like Encrypt= or
#     TrustServerCertificate= or want to switch driver (e.g. Driver 17 on
#     Windows containers). Set ONE string; the runtime drops it verbatim
#     into every ODBC_INFO row.
#SQL_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=your.sql.host,1433;UID=sa;PWD=YourPassword;Encrypt=yes;TrustServerCertificate=yes
#
#   Tier 2 -- server + password, default driver. Set SQL_HOST and the
#     runtime rewrites SERVER= / PWD= in each ODBC_INFO row.
#SQL_HOST=your.sql.server.host
#SQL_PORT=1433
#
#   Tier 3 -- bundled container (default). The `bundled-sql` profile brings
#     it up; SQL_HOST falls through to its compose service name "sqlserver".
COMPOSE_PROFILES=bundled-sql
#
# See ../README.md "Using an external SQL Server (BYO-SQL)" for what to
# pre-create on your external SQL Server before flipping tier 1 or 2.

# --- Optional -----------------------------------------------------------------

# Host directory that holds the GamigoZR crypt blob. The startup
# script expects response.txt inside it. Extract from a real GamigoZR.exe once
# (see Dockerfile.gamigozr-stub in the repo root for the curl recipe), then
# drop the file into ./gamigozr-blob/response.txt and leave this commented.
# Override only if your blob lives somewhere else.
#CRYPT_BLOB=./gamigozr-blob

# Host directory that holds your BYO XOR table for the c2s cipher. The proxy
# reads it to decrypt C->S packets for logging only (it never re-encrypts; the
# wire bytes pass through unchanged). The proxy runs fine without a table.
#XOR_BLOB=./xor
#XOR_TABLE_PATH=C:\xor\xor.hex

# Or pass the table inline as hex (wins over XOR_TABLE_PATH if both are set):
#XOR_TABLE_HEX=00112233...

# Per-packet trace logging in the proxy. Off by default. Set to 1 only when
# actively debugging a session -- it's very chatty.
#PROXY_PACKET_LOG=1

# Where the bundled SQL container's data files live on the host. Defaults to
# ./sql-data next to the compose file. Keep this on a bind mount (not a named
# volume) so accidental `docker compose down -v` can't delete your characters.
# Has no effect when COMPOSE_PROFILES doesn't include `bundled-sql`.
#SQL_DATA_DIR=./sql-data

# Keep the runtime containers alive after the game exe exits, so you can
# `docker exec` in and poke around. Defaults to 0 (container exits when exe exits).
#KEEP_ALIVE=1

# DB-bridge self-heal: if a DB bridge loses its SQL connection (e.g. the SQL
# container is recreated), it exits so the restart policy reconnects with a
# fresh handle instead of silently sitting on a dead connection. On by default;
# set to 0 to disable.
#DB_AUTORESTART=0
